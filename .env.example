# ---- AthenaBot environment ----
# Copy to ".env" on the server (or set these as systemd Environment= lines).
# Do NOT commit a filled-in .env to source control.

# Port the Node app listens on (nginx proxies to this).
PORT=8080

# Optional shared secret. When set, the voice platform must send it as the
# "x-athenabot-secret" header on webhook calls, or they are rejected (401).
# Leave blank during the on-page demo so the browser demo can call the API.
WEBHOOK_SECRET=

# ---- Scheduling provider (mock until configured) ----
SCHEDULING_PROVIDER=
SCHEDULING_API_KEY=

# ---- EHR / EMR over FHIR (mock until configured) ----
# Public sandbox for testing (NO real PHI): https://hapi.fhir.org/baseR4
EHR_FHIR_BASE_URL=
EHR_FHIR_TOKEN=

# ---- Voice platform (used when you wire up a real phone agent) ----
# RETELL_API_KEY=
# VAPI_API_KEY=
