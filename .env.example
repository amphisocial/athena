# Copy this file to .env and fill in real values. Never commit the real .env file.

# --- SMTP credentials from your email provider ---
# Google Workspace: smtp.gmail.com, port 587, SMTP_SECURE=false, use an App Password.
# Microsoft 365: smtp.office365.com, port 587, SMTP_SECURE=false.
# SendGrid: smtp.sendgrid.net, port 587, SMTP_USER=apikey, SMTP_PASS=<SendGrid API key>.
# Amazon SES/Postmark/Mailgun: use the SMTP host and credentials from that provider.
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# --- Contact form destination ---
CONTACT_TO_EMAIL=anu@threadwire.ai

# The from address on outgoing mail. Many providers require this to match SMTP_USER
# or a verified sender/domain.
CONTACT_FROM_EMAIL=your-smtp-username

# Comma-separated allowed origins. Use the production domain in production.
SITE_ORIGIN=https://athenabot.ai,https://www.athenabot.ai

# Internal Node port. Nginx will proxy 80/443 to this localhost port.
PORT=3000
