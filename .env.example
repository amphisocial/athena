# Copy this file to .env and fill in real values. Never commit the real .env file.

# --- SMTP credentials (from your email provider) ---
# Examples:
#   Google Workspace: smtp.gmail.com, port 587, SMTP_SECURE=false (use an App Password, not your login password)
#   Microsoft 365:    smtp.office365.com, port 587, SMTP_SECURE=false
#   SendGrid:         smtp.sendgrid.net, port 587, SMTP_USER=apikey, SMTP_PASS=<your SendGrid API key>
#   Postmark/Mailgun/SES: use the SMTP host + credentials from that provider's dashboard
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# --- Where the contact form sends inquiries ---
CONTACT_TO_EMAIL=anu@threadwire.ai

# The "from" address on the outgoing email. Many providers require this to match
# the authenticated SMTP_USER (or a verified domain) or it will be rejected/spam-flagged.
CONTACT_FROM_EMAIL=your-smtp-username

# --- CORS: restrict which site origin is allowed to call this API ---
SITE_ORIGIN=https://athenabot.ai

# --- Server port ---
PORT=3000
